# AI Configuration for ChronoKids
# Copy this to .env.local and add your API key

# OpenAI API Key for dynamic content generation
# Server-side only: set this in Vercel Project Settings > Environment Variables
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4-turbo-preview

# Supabase Configuration
# These are safe to expose to the browser and should also be set in Vercel.
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
